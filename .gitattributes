# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Explicit text
*.py        text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
Makefile    text eol=lf
Dockerfile  text eol=lf
LICENSE     text eol=lf

# Binary — do not diff or merge
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.gz        binary
*.zip       binary
