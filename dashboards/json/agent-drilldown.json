{
  "uid": "agent-drilldown",
  "title": "Agent Drilldown",
  "description": "Per-agent analysis of MCP honeypot interactions",
  "tags": ["mcp-honeypot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "agent_id",
        "label": "Agent ID",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(mcp_honeypot_mcp_tool_calls_total, agent_id)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Session Timeline",
      "description": "Tool calls over time for the selected agent",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tool) (rate(mcp_honeypot_mcp_tool_calls_total{agent_id=\"$agent_id\"}[1m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 80,
            "pointSize": 5,
            "showPoints": "never",
            "stacking": { "mode": "normal", "group": "A" },
            "spanNulls": false
          },
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Tools Called",
      "description": "Distribution of tool calls for the selected agent",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tool) (increase(mcp_honeypot_mcp_tool_calls_total{agent_id=\"$agent_id\"}[1h]))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 3,
      "title": "Anomaly Flags Triggered",
      "description": "Anomaly flags detected for the selected agent",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (flag) (increase(mcp_honeypot_mcp_anomalies_total{agent_id=\"$agent_id\"}[1h]))",
          "legendFormat": "{{flag}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Count" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Count", "desc": true }],
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "flag": "Anomaly Flag",
              "Value": "Count"
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Jaeger Trace Links",
      "description": "Recent traces for the selected agent — click to open in Jaeger",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "jaeger", "uid": "jaeger" },
      "targets": [
        {
          "query": "$agent_id",
          "queryType": "search",
          "refId": "A",
          "service": "mcp-honeypot",
          "tags": "agent.id=$agent_id",
          "limit": 20
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          },
          "links": [
            {
              "title": "View in Jaeger",
              "url": "http://localhost:16686/trace/${__data.fields.traceID}",
              "targetBlank": true
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "footer": { "show": false }
      }
    }
  ]
}
