{
  "uid": "tool-intelligence",
  "title": "Tool Intelligence",
  "description": "Tool usage patterns and co-occurrence analysis for MCP honeypot",
  "tags": ["mcp-honeypot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Tool Call Frequency Heatmap",
      "description": "Tool calls by tool name over time (approximates tool x hour pattern)",
      "type": "heatmap",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tool) (increase(mcp_honeypot_mcp_tool_calls_total[1h]))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "hideFrom": { "tooltip": false, "viz": false, "legend": false }
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": true,
        "calculation": {
          "xBuckets": { "mode": "size", "value": "1h" }
        },
        "color": {
          "mode": "scheme",
          "scheme": "Blues",
          "steps": 64
        },
        "cellGap": 1,
        "yAxis": {
          "axisPlacement": "left"
        },
        "tooltip": {
          "show": true,
          "yHistogram": false
        },
        "legend": { "show": true }
      }
    },
    {
      "id": 2,
      "title": "Average Chain Depth per Session",
      "description": "Average number of distinct tool calls per active session",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(count by (session_id) (mcp_honeypot_mcp_tool_calls_total))",
          "legendFormat": "Avg Chain Depth",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Tool Co-occurrence Matrix",
      "description": "Placeholder: requires T19 recording rules (mcp_honeypot:tool_cooccurrence:rate5m). Currently shows per-agent tool diversity as a proxy.",
      "type": "table",
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tool) (increase(mcp_honeypot_mcp_tool_calls_total[1h]))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [
              { "id": "custom.hidden", "value": true }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Calls (1h)" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Calls (1h)", "desc": true }],
        "footer": {
          "show": true,
          "reducer": ["sum"],
          "fields": ["Value"]
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": {
              "tool": "Tool",
              "Value": "Calls (1h)"
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Tool Usage Over Time",
      "description": "Per-tool call rate over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tool) (rate(mcp_honeypot_mcp_tool_calls_total[5m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "none", "group": "A" }
          },
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    }
  ]
}
