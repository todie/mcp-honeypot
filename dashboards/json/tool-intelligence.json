{
  "uid": "tool-intelligence",
  "title": "MCP Honeypot — Tool Intelligence",
  "description": "Research and analysis view: tool usage frequency, response latency distributions, category breakdowns, and co-occurrence patterns across all 13 honeypot tools.",
  "tags": ["mcp-honeypot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "editable": true,
  "style": "dark",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "24h"]
  },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Unique Tools Used",
      "description": "Number of distinct tools invoked (of 13 available)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(count by (tool) (mcp_honeypot_mcp_tool_calls_total))",
          "legendFormat": "Unique Tools",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Waiting for data...",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#B877D9", "value": null }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short",
          "decimals": 0,
          "max": 13
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name",
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "title": "Most Called Tool",
      "description": "The single most invoked tool across all agents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(1, sum by (tool) (increase(mcp_honeypot_mcp_tool_calls_total[$__range])))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Waiting for data...",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#5794F2", "value": null }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "name",
        "orientation": "auto"
      }
    },
    {
      "id": 3,
      "title": "Avg Calls Per Session",
      "description": "Average number of tool calls per active session",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(count by (session_id) (mcp_honeypot_mcp_tool_calls_total))",
          "legendFormat": "Avg Calls/Session",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Waiting for data...",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#B877D9", "value": null },
              { "color": "#FADE2A", "value": 10 },
              { "color": "#F2495C", "value": 20 }
            ]
          },
          "color": { "mode": "thresholds" },
          "unit": "short",
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
      "id": 10,
      "title": "Tool Call Frequency",
      "description": "All 13 tools sorted by total invocations",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sort_desc(sum by (tool) (increase(mcp_honeypot_mcp_tool_calls_total[$__range])))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Waiting for data...",
          "color": {
            "mode": "continuous-BlPu"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "tool": "Tool", "Value": "Calls" }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Calls", "desc": true }] }
        }
      ]
    },
    {
      "id": 11,
      "title": "Tool Usage Over Time (Top 5)",
      "description": "Stacked area of the 5 most-called tools over time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(5, sum by (tool) (rate(mcp_honeypot_mcp_tool_calls_total[5m])))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Waiting for data...",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 35,
            "gradientMode": "scheme",
            "pointSize": 5,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" },
            "axisBorderShow": false
          },
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean", "max"] }
      }
    },
    {
      "id": 20,
      "title": "Response Latency by Tool",
      "description": "Average response latency per tool (from recording rules)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "mcp_honeypot:response_latency_by_tool:avg5m",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Waiting for data...",
          "color": {
            "mode": "continuous-YlRd"
          },
          "unit": "ms",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 10 },
              { "color": "#F2495C", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "xTickLabelRotation": 0,
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": { "displayMode": "hidden" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "tool": "Tool", "Value": "Avg Latency (ms)" }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": {}, "sort": [{ "field": "Avg Latency (ms)", "desc": true }] }
        }
      ]
    },
    {
      "id": 21,
      "title": "Latency Over Time",
      "description": "Per-tool average response latency trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (tool) (rate(mcp_honeypot_mcp_response_latency_ms_sum[5m])) / sum by (tool) (rate(mcp_honeypot_mcp_response_latency_ms_count[5m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Waiting for data...",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "pointSize": 5,
            "lineWidth": 2,
            "showPoints": "auto",
            "spanNulls": false,
            "axisBorderShow": false
          },
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      }
    },
    {
      "id": 30,
      "title": "Tool Category Distribution",
      "description": "Calls grouped into filesystem, web, exec, and secrets categories",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(mcp_honeypot_mcp_tool_calls_total{tool=~\"read_file|write_file|list_directory|delete_file\"}[$__range]))",
          "legendFormat": "Filesystem",
          "refId": "A",
          "instant": true
        },
        {
          "expr": "sum(increase(mcp_honeypot_mcp_tool_calls_total{tool=~\"fetch_url|web_search|http_request\"}[$__range]))",
          "legendFormat": "Web",
          "refId": "B",
          "instant": true
        },
        {
          "expr": "sum(increase(mcp_honeypot_mcp_tool_calls_total{tool=~\"run_command|execute_script|shell_exec\"}[$__range]))",
          "legendFormat": "Exec",
          "refId": "C",
          "instant": true
        },
        {
          "expr": "sum(increase(mcp_honeypot_mcp_tool_calls_total{tool=~\"get_env|read_credentials|access_secrets\"}[$__range]))",
          "legendFormat": "Secrets",
          "refId": "D",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Waiting for data...",
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Filesystem" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Web" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Exec" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Secrets" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["percent", "value"] },
        "tooltip": { "mode": "single", "sort": "none" },
        "displayLabels": ["name", "percent"]
      }
    },
    {
      "id": 31,
      "title": "Tool Co-occurrence (Agent-Tool Matrix)",
      "description": "Which tools are used together by the same agents, using recording rule mcp_honeypot:tool_calls_by_agent:rate5m",
      "type": "table",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(30, sum by (agent_id, tool) (mcp_honeypot:tool_calls_by_agent:rate5m) > 0)",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Waiting for data...",
          "unit": "reqps",
          "decimals": 4,
          "custom": {
            "align": "auto",
            "filterable": true,
            "cellOptions": { "type": "auto" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "agent_id" },
            "properties": [
              { "id": "displayName", "value": "Agent" },
              { "id": "custom.width", "value": 160 },
              { "id": "links", "value": [
                {
                  "title": "Drill down",
                  "url": "/d/agent-drilldown/mcp-honeypot-agent-drilldown?var-agent_id=${__data.fields.agent_id}",
                  "targetBlank": false
                }
              ]}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "tool" },
            "properties": [
              { "id": "displayName", "value": "Tool" },
              { "id": "custom.width", "value": 160 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#B877D9" } },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Rate (req/s)" },
              { "id": "custom.width", "value": 120 },
              { "id": "color", "value": { "mode": "continuous-BlPu" } },
              { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Agent", "desc": false }],
        "footer": {
          "show": true,
          "reducer": ["count"],
          "fields": ["Value"]
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "indexByName": { "agent_id": 0, "tool": 1, "Value": 2 },
            "renameByName": {
              "agent_id": "Agent",
              "tool": "Tool",
              "Value": "Rate (req/s)"
            }
          }
        }
      ]
    }
  ]
}
