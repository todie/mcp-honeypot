# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# OTLP gRPC endpoint for the OTel Collector (or any OTLP-compatible backend)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Service name appears in all traces and metrics
OTEL_SERVICE_NAME=mcp-honeypot

# ── MCP Honeypot Server ───────────────────────────────────────────────────────
# Port the MCP HTTP/SSE server listens on
HONEYPOT_PORT=8000

# Transport mode: sse | stdio
HONEYPOT_TRANSPORT=sse

# ── Logging ───────────────────────────────────────────────────────────────────
# Structured log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── Session / Detection ───────────────────────────────────────────────────────
# Time window (seconds) for the exfiltration_chain anomaly detector.
# If a read-family tool call is followed by a network-family call within
# this window in the same session, an exfiltration_chain flag is emitted.
SESSION_EXFIL_TTL_SECONDS=120

# ── CORS (Phase 3) ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for Phase 1/2 (open).
# Tighten this for Phase 3 public exposure.
CORS_ORIGINS=*

# ── Grafana ───────────────────────────────────────────────────────────────────
# Default admin credentials for the Grafana container
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=honeypot

# ── Prometheus ────────────────────────────────────────────────────────────────
# Data retention: time-based (e.g. 30d) or size-based (e.g. 10GB)
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=10GB
