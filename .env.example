# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# OTLP gRPC endpoint for the OTel Collector (or any OTLP-compatible backend)
# config.py reads: OTLP_ENDPOINT
OTLP_ENDPOINT=otel-collector:4317

# Whether to skip TLS verification for the OTLP endpoint
# Only "false" disables; any other value (or unset) means insecure=true
OTLP_INSECURE=true

# Service name appears in all traces and metrics
# config.py reads: SERVICE_NAME
SERVICE_NAME=mcp-honeypot

# ── MCP Honeypot Server ───────────────────────────────────────────────────────
# Host and port the MCP HTTP/SSE server listens on
# config.py reads: MCP_HOST, MCP_PORT
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Honeypot phase: research | public
# In "public" phase, HONEYPOT_WEBHOOK_SECRET is required
HONEYPOT_PHASE=research
# HONEYPOT_WEBHOOK_SECRET=  # required when HONEYPOT_PHASE=public

# ── Logging ───────────────────────────────────────────────────────────────────
# Structured log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── CORS (Phase 3) ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for Phase 1/2 (open).
# Tighten this for Phase 3 public exposure.
CORS_ORIGINS=*

# ── Grafana ───────────────────────────────────────────────────────────────────
# Default admin credentials for the Grafana container
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=honeypot

# ── Prometheus ────────────────────────────────────────────────────────────────
# Data retention: time-based (e.g. 30d) or size-based (e.g. 10GB)
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_RETENTION_SIZE=10GB

# ── Alerting ──────────────────────────────────────────────────────────────────
# Alert webhook URL (optional, for Grafana alert notifications)
ALERT_WEBHOOK_URL=http://localhost:9999/alerts
